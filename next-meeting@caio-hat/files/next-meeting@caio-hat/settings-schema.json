{
    "layout": {
        "type": "layout",
        "pages": ["main", "advanced", "help"],
        "main": {
            "type": "page",
            "title": "General",
            "sections": ["calendars-section", "panel-section", "privacy-section"]
        },
        "advanced": {
            "type": "page",
            "title": "Advanced",
            "sections": ["notifications-section", "refresh-section"]
        },
        "help": {
            "type": "page",
            "title": "Help",
            "sections": ["help-icons-section", "help-panel-section", "help-tips-section", "help-about-section"]
        },
        "calendars-section": {
            "type": "section",
            "title": "Calendars",
            "keys": ["calendars"]
        },
        "panel-section": {
            "type": "section",
            "title": "Panel and Popup",
            "keys": ["show-in-panel", "label-max-chars", "timer-position", "marquee-enabled", "marquee-speed", "show-tentative", "show-tentative-in-panel"]
        },
        "privacy-section": {
            "type": "section",
            "title": "Privacy",
            "keys": ["hidden-mode", "hide-subject"]
        },
        "notifications-section": {
            "type": "section",
            "title": "Notifications",
            "keys": ["notify-enabled", "notify-before", "notify-conflicts"]
        },
        "refresh-section": {
            "type": "section",
            "title": "Refresh",
            "keys": ["refresh-interval"]
        },
        "help-icons-section": {
            "type": "section",
            "title": "Status icons",
            "keys": ["help-icon-live", "help-icon-accepted", "help-icon-tentative", "help-icon-conflict", "help-icon-link"]
        },
        "help-panel-section": {
            "type": "section",
            "title": "Panel indicators",
            "keys": ["help-panel-check", "help-panel-clock", "help-panel-dash", "help-panel-warn"]
        },
        "help-tips-section": {
            "type": "section",
            "title": "Tips",
            "keys": ["help-tip-click", "help-tip-add", "help-tip-hidden", "help-tip-marquee", "help-tip-notify"]
        },
        "help-about-section": {
            "type": "section",
            "title": "About",
            "keys": ["help-about-feeds", "help-about-url"]
        }
    },
    "calendars": {
        "type": "list",
        "description": "Calendars (Google, Outlook, Apple, Nextcloud... ICS/iCal URLs)",
        "columns": [
            { "id": "enabled", "title": "Active",      "type": "boolean" },
            { "id": "name",    "title": "Name",        "type": "string" },
            { "id": "url",     "title": "ICS URL",     "type": "string", "ellipsize": "end", "max-width": 280 },
            { "id": "color",   "title": "Color (hex)", "type": "string" }
        ],
        "default": []
    },
    "show-in-panel": {
        "type": "switch",
        "default": true,
        "description": "Show text in panel (disable for No Display Mode - icon only)"
    },
    "label-max-chars": {
        "type": "spinbutton",
        "default": 40,
        "min": 10,
        "max": 100,
        "step": 1,
        "units": "characters",
        "description": "Maximum text length in panel"
    },
    "timer-position": {
        "type": "combobox",
        "default": "start",
        "description": "Timer position in panel label",
        "options": {
            "Before meeting name": "start",
            "After meeting name": "end"
        }
    },
    "marquee-enabled": {
        "type": "switch",
        "default": false,
        "description": "Scrolling text in panel when name is too long (marquee)"
    },
    "marquee-speed": {
        "type": "spinbutton",
        "default": 4,
        "min": 1,
        "max": 20,
        "step": 1,
        "units": "px/frame",
        "description": "Scroll speed (1=slow, 20=fast)"
    },
    "show-tentative": {
        "type": "switch",
        "default": true,
        "description": "Show tentative meetings in popup"
    },
    "show-tentative-in-panel": {
        "type": "switch",
        "default": true,
        "description": "Show tentative meetings in panel (chronological order)",
        "tooltip": "When ON, the panel shows the next meeting by time regardless of status. When OFF, only accepted meetings appear in the panel."
    },
    "hidden-mode": {
        "type": "switch",
        "default": false,
        "description": "Hidden Mode: shows only the remaining time (countdown), hides meeting name and time in panel. Useful for screen sharing or recording."
    },
    "hide-subject": {
        "type": "switch",
        "default": false,
        "description": "Hide meeting subject (show only time + countdown)",
        "tooltip": "Less drastic than Hidden Mode. Useful when you want to keep timing visible but hide names from screen sharing."
    },
    "notify-enabled": {
        "type": "switch",
        "default": true,
        "description": "Notify before meeting starts"
    },
    "notify-before": {
        "type": "spinbutton",
        "default": 30,
        "min": 1,
        "max": 120,
        "step": 1,
        "units": "minutes",
        "description": "Reminder advance time"
    },
    "notify-conflicts": {
        "type": "switch",
        "default": true,
        "description": "Notify on time conflicts (critical urgency)"
    },
    "refresh-interval": {
        "type": "spinbutton",
        "default": 5,
        "min": 1,
        "max": 60,
        "step": 1,
        "units": "minutes",
        "description": "Calendar refresh interval"
    },
    "help-icon-live": {
        "type": "label",
        "description": "◎  Live meeting in progress"
    },
    "help-icon-accepted": {
        "type": "label",
        "description": "●  Accepted meeting (uses calendar color)"
    },
    "help-icon-tentative": {
        "type": "label",
        "description": "?  Tentative / pending response"
    },
    "help-icon-conflict": {
        "type": "label",
        "description": "⚠  Time conflict between meetings"
    },
    "help-icon-link": {
        "type": "label",
        "description": "🔗  Has join link — click the meeting to open it"
    },
    "help-panel-check": {
        "type": "label",
        "description": "✓  All today's meetings are done — next one is on another day"
    },
    "help-panel-clock": {
        "type": "label",
        "description": "⏱  Hidden Mode countdown"
    },
    "help-panel-dash": {
        "type": "label",
        "description": "—  Hidden Mode with no meetings ahead"
    },
    "help-panel-warn": {
        "type": "label",
        "description": "⚠  Prefix on panel label marks an active time conflict"
    },
    "help-tip-click": {
        "type": "label",
        "description": "Click the applet to open the popup menu."
    },
    "help-tip-add": {
        "type": "label",
        "description": "Right-click the applet → Configure → add an ICS/iCal URL."
    },
    "help-tip-hidden": {
        "type": "label",
        "description": "Hidden Mode shows only the countdown — useful for screen sharing or recording."
    },
    "help-tip-marquee": {
        "type": "label",
        "description": "Marquee scrolls long meeting names without moving the icon."
    },
    "help-tip-notify": {
        "type": "label",
        "description": "Notifications fire before a meeting starts (configurable on the Advanced tab)."
    },
    "help-about-feeds": {
        "type": "label",
        "description": "Works with any RFC 5545 ICS/iCal feed: Google, Outlook, Apple, Nextcloud, Fastmail, Proton."
    },
    "help-about-url": {
        "type": "label",
        "description": "github.com/caio-hat/cinnamon-applet-next-meeting"
    }
}
