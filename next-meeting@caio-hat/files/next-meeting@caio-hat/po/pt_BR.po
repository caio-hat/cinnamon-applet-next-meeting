msgstr "Ativo"

msgid "Show text in panel (disable for No Display Mode - icon only)"
msgstr "Exibir texto na barra (desligue para Modo Sem Exibição - apenas ícone)"

msgid "Maximum text length in panel"
msgstr "Tamanho máximo do texto na barra"

msgid "characters"
msgstr "caracteres"

msgid "Timer position in panel label"
msgstr "Posição do horário na barra"

msgid "Before meeting name"
msgstr "Antes do nome da reunião"

msgid "After meeting name"
msgstr "Após o nome da reunião"

msgid "Scrolling text in panel when name is too long (marquee)"
msgstr "Texto rolante na barra quando o nome é longo (marquee)"

msgid "Scroll speed (1=fast, 20=slow)"
msgstr "Velocidade de rolagem (1=rápido, 20=lento)"

msgid "Show tentative meetings in popup"
msgstr "Exibir reuniões pendentes/tentativas no menu"

msgid "Show tentative meetings in panel (chronological order)"
msgstr "Mostrar reuniões pendentes/tentativas na barra (ordem cronológica)"

msgid "When ON, the panel shows the next meeting by time regardless of status. When OFF, only accepted meetings appear in the panel."
msgstr "Quando ativo, a barra mostra a próxima reunião por horário, independente do status. Quando desativado, apenas reuniões aceitas aparecem na barra."

# Help page (Settings)
msgid "Help"
msgstr "Ajuda"

msgid "Status icons"
msgstr "Ícones de status"

msgid "Panel indicators"
msgstr "Indicadores na barra"

msgid "Tips"
msgstr "Dicas"

msgid "About"
msgstr "Sobre"

msgid "◎  Live meeting in progress"
msgstr "◎  Reunião em andamento"

msgid "●  Accepted meeting (uses calendar color)"
msgstr "●  Reunião aceita (usa a cor do calendário)"

msgid "?  Tentative / pending response"
msgstr "?  Pendente / aguardando resposta"

msgid "⚠  Time conflict between meetings"
msgstr "⚠  Conflito de horário entre reuniões"

msgid "🔗  Has join link — click the meeting to open it"
msgstr "🔗  Possui link de entrada — clique na reunião para abrir"

msgid "✓  All today's meetings are done — next one is on another day"
msgstr "✓  Reuniões de hoje concluídas — próxima é em outro dia"

msgid "⏱  Hidden Mode countdown"
msgstr "⏱  Contagem regressiva no Modo Oculto"

msgid "—  Hidden Mode with no meetings ahead"
msgstr "—  Modo Oculto sem reuniões à frente"

msgid "⚠  Prefix on panel label marks an active time conflict"
msgstr "⚠  Prefixo na barra indica conflito de horário ativo"

msgid "Click the applet to open the popup menu."
msgstr "Clique no applet para abrir o menu pop-up."

msgid "Right-click the applet → Configure → add an ICS/iCal URL."
msgstr "Clique direito no applet → Configurar → adicione uma URL ICS/iCal."

msgid "Hidden Mode shows only the countdown — useful for screen sharing or recording."
msgstr "O Modo Oculto mostra apenas a contagem regressiva — útil para compartilhamento ou gravação de tela."

msgid "Marquee scrolls long meeting names without moving the icon."
msgstr "O Marquee rola nomes longos sem mover o ícone."

msgid "Notifications fire before a meeting starts (configurable on the Advanced tab)."
msgstr "As notificações disparam antes da reunião começar (configurável na aba Avançado)."

msgid "Works with any RFC 5545 ICS/iCal feed: Google, Outlook, Apple, Nextcloud, Fastmail, Proton."
msgstr "Funciona com qualquer feed ICS/iCal RFC 5545: Google, Outlook, Apple, Nextcloud, Fastmail, Proton."

msgid "github.com/caio-hat/cinnamon-applet-next-meeting"
msgstr "github.com/caio-hat/cinnamon-applet-next-meeting"

# v2.5 — all-day events, snooze, hide-subject
msgid "All day"
msgstr "Dia inteiro"

msgid "Snooze 5 min"
msgstr "Adiar 5 min"

msgid "Snooze 15 min"
msgstr "Adiar 15 min"

msgid "Dismiss"
msgstr "Dispensar"

msgid "Hide meeting subject (show only time + countdown)"
msgstr "Ocultar assunto da reunião (mostrar apenas horário + contagem regressiva)"

msgid "Less drastic than Hidden Mode. Useful when you want to keep timing visible but hide names from screen sharing."
msgstr "Menos drástico que o Modo Oculto. Útil para manter o horário visível e esconder nomes ao compartilhar tela."

msgid "Hide subject (show time only)"
msgstr "Ocultar assunto (mostrar só horário)"

msgid "Subject hidden — click the icon to see details"
msgstr "Assunto oculto — clique no ícone para ver detalhes"

msgid "Hidden Mode: shows only the remaining time (countdown), hides meeting name and time in panel. Useful for screen sharing or recording."
msgstr "Modo Oculto: mostra apenas o tempo restante (contagem regressiva), oculta nome e horário da reunião na barra. Útil para compartilhamento ou gravação de tela."

msgid "Notify before meeting starts"
msgstr "Notificar antes da reunião começar"

msgid "Reminder advance time"
msgstr "Antecedência do lembrete"

msgid "minutes"
msgstr "minutos"

msgid "Notify on time conflicts (critical urgency)"
msgstr "Notificar conflitos de horário (urgência crítica)"

msgid "Calendar refresh interval"
msgstr "Intervalo de atualização do calendário"
